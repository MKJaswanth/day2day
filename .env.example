# --- Supabase ---------------------------------------------------------------
# Project Settings → Data API  (and  Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# --- Database (Drizzle) -----------------------------------------------------
# Project Settings → Database → Connection string → "Transaction pooler" (port 6543)
# Use the pooler URL for the app; URL-encode any special chars in the password.
DATABASE_URL=postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
